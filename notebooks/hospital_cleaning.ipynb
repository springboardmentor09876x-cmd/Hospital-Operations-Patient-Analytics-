        "    path = 'hospital_master_dataset.csv' if os.path.exists('hospital_master_dataset.csv') else 'hospital_raw_data.csv'\n",
        "\n",
        "df = pd.read_csv(path)\n",
        "print(f'Initial Dataset Shape: {df.shape}')\n",
