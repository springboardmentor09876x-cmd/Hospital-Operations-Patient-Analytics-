import pandas as pd
import numpy as np

# 1. Load the master dataset
df = pd.read_csv('hospital_master_dataset.csv')

# 2. Check and handle missing values
print("Initial Missing Values:\n", df.isnull().sum())
# Drop completely duplicate records if any exist
df = df.drop_duplicates()

# 3. Standardize Data Types
df['Admission Date'] = pd.to_datetime(df['Admission Date'])
df['Discharge Date'] = pd.to_datetime(df['Discharge Date'])

# 4. Standardize text columns (Remove trailing spaces, fix casing)
text_cols = ['Department', 'Diagnosis', 'Gender', 'Admission Type', 'Hospital Name']
for col in text_cols:
    if col in df.columns:
        df[col] = df[col].astype(str).str.strip().str.title()

print("\nData Cleaning Complete! Checking missing percentages...")
print((df.isnull().sum() / len(df)) * 100)

import pandas as pd
import numpy as np

# Load the raw integrated master file
df = pd.read_csv('hospital_master_dataset.csv')

# 1. Remove duplicate records
df = df.drop_duplicates()

# 2. Handle missing patient data
df['Medication'] = df['Medication'].fillna('None Specified')
df['Equipment'] = df['Equipment'].fillna('None Used')

# 3. Standardize department names
df['Department'] = df['Department'].astype(str).str.strip().str.title()

# 4. Normalize healthcare indicators
indicator_cols = ['Severity_Level', 'Severity', 'Outcome', 'Test Result']
for col in indicator_cols:
    if col in df.columns:
        df[col] = df[col].astype(str).str.strip().str.title()

# 5. Save the Tableau-Ready Clean Dataset
df.to_csv('hospital_cleaned.csv', index=False)
print("Data Cleaning Complete! 'hospital_cleaned.csv' exported.")