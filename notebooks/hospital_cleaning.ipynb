        "### Task 1: Remove Duplicate Records"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": None,
      "metadata": {},
      "outputs": [],
      "source": [
        "initial_rows = len(df)\n",
        "df = df.drop_duplicates()\n",
        "print(f'Duplicates removed. Rows dropped: {initial_rows - len(df)}')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### Task 2: Handle Missing Patient Data"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": None,
      "metadata": {},
      "outputs": [],
      "source": [
        "missing_counts = df.isnull().sum()\n",
        "print(missing_counts[missing_counts > 0])\n",
        "if 'Medication' in df.columns:\n",
        "    df['Medication'] = df['Medication'].fillna('None Specified')\n",
        "if 'Equipment' in df.columns:\n",
        "    df['Equipment'] = df['Equipment'].fillna('None Used')\n",
        "print(f'Remaining missing values: {df.isnull().sum().sum()}')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### Task 3: Standardize Department Names"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": None,
      "metadata": {},
      "outputs": [],
      "source": [
        "df['Department'] = df['Department'].astype(str).str.strip().str.title()\n",
        "print(df['Department'].unique())"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### Task 4: Normalize Healthcare Indicators & Explicit Date Formatting"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": None,
      "metadata": {},
      "outputs": [],
      "source": [
        "indicator_cols = ['Severity_Level', 'Severity', 'Outcome', 'Test Result']\n",
        "for col in indicator_cols:\n",
        "    if col in df.columns:\n",
        "        df[col] = df[col].astype(str).str.strip().str.title()\n",
        "\n",
        "date_cols = ['Admission Date', 'Discharge Date', 'Transfer_Date']\n",
        "for col in date_cols:\n",
        "    if col in df.columns:\n",
        "        df[col] = pd.to_datetime(df[col]).dt.strftime('%Y-%m-%d')\n",
        "print('Normalization complete.')"
      ]
